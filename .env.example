# Copy this file to `.env` and fill in the keys for the providers you want to use.
# Only the keys for models listed in config.json need to be set.

# OpenAI (GPT-4o, GPT-4.1, text-embedding-3-small, GPT-4o-mini judge)
OPENAI_API_KEY=

# Anthropic (Claude-Sonnet-4, Claude-Sonnet-3.7)
ANTHROPIC_API_KEY=

# Google (Gemini-2.5-Pro, Gemini-2.5-Flash; and Search Grounding)
GOOGLE_API_KEY=

# OpenAI-compatible endpoints (vLLM / Together / DashScope / etc.) used for Qwen
# Leave empty to use Hugging Face transformers locally.
QWEN_API_BASE=
QWEN_API_KEY=
