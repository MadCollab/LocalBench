{
  "data_dir": "data",
  "output_dir": "outputs",

  "datasets": ["census", "reddit", "news"],

  "models": [
    "gpt-4o",
    "gpt-4.1",
    "claude-sonnet-4",
    "gemini-2.5-pro",
    "qwen3-8b"
  ],

  "metrics": {
    "exact_match": true,
    "rouge1": true,
    "semantic_match": true,
    "numerical_accuracy": true,
    "gpt_judge": true,
    "answer_rate": true
  },

  "query": {
    "temperature": 0.0,
    "max_tokens": 256,
    "num_runs": 1,
    "seeds": [0],
    "concurrency": 4,
    "rate_limit_seconds": 0.0,
    "include_context": false,
    "resume": true
  },

  "evaluate": {
    "numerical_tolerance": 0.02,
    "embedding_model": "text-embedding-3-small",
    "judge_model": "gpt-4o-mini"
  },

  "sample_size_per_dataset": null,
  "random_seed": 42
}
